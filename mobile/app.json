{
  "expo": {
    "name": "Trader Sentinel",
    "slug": "trader-sentinel",
    "owner": "cryptohunterthronosnetwork",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tradersentinel",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E27"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thronos.tradersentinel",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for QR code scanning",
        "NSFaceIDUsageDescription": "Used for secure authentication"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E27"
      },
      "package": "com.thronos.tradersentinel",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6366F1"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bbd11581-ab6c-4421-8b16-8e9269987705"
      },
      "apiUrl": "https://sentinel.thronoschain.org",
      "analystUrl": "https://alanisys.up.railway.app",
      "brainUrl": "https://your-brain-service.up.railway.app",
      "walletConnectProjectId": "b4954b0dc4eb9832e0f03ef0f25cc744"
    }
  }
}
