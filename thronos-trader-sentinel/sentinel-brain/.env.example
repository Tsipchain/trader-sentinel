# ── sentinel-brain environment variables ────────────────────────────────────
# Set these in Railway. PORT is injected automatically — do NOT override.

# ── API Security ──────────────────────────────────────────────────────────────
# Must match API_KEY set on backend and mobile EXPO_PUBLIC_API_KEY.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# ── Volume Persistence ────────────────────────────────────────────────────────
# Root path of the Railway persistent volume (50 GB, mounted at /disckb).
# All subdirectories are created automatically on first write:
#   $DISK_PATH/models/      — per-user ML model pickle files (.pkl)
#   $DISK_PATH/history/     — per-user matched trade records (JSON)
#   $DISK_PATH/autotrader/  — per-user AutoTrader session configs (JSON)
#
# On Railway: set DISK_PATH to the volume mount path → /disckb
# For local dev: use any writable directory, e.g. /tmp/brain-dev
DISK_PATH=/disckb

# Optional: PORT is set by Railway automatically.
# For local dev only:
PORT=8083
