# ── sentinel-brain environment variables ────────────────────────────────────
# Set these in Railway. PORT is injected automatically — do NOT override.

# ── API Security ──────────────────────────────────────────────────────────────
# Must match API_KEY set on backend and mobile EXPO_PUBLIC_API_KEY.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# ── Model Persistence ─────────────────────────────────────────────────────────
# Directory where per-user ML models are pickled.
# On Railway with a volume mount, set this to the volume path, e.g. /data/models
# Without a volume, models still persist within a single container session but
# are lost on redeploy (add a Railway Volume at /data to survive deploys).
MODELS_DIR=/models

# Optional: PORT is set by Railway automatically.
# For local dev only:
PORT=8083
