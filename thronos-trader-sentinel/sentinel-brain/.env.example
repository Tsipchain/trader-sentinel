# ── sentinel-brain environment variables ────────────────────────────────────
# Set these in Railway. PORT is injected automatically — do NOT override.

# No required variables — the service starts without any configuration.
# All user data (exchange keys + models) is held in-memory.
# For production persistence, add a DATABASE_URL (Postgres/Redis) later.

# Optional: PORT is set by Railway automatically.
# For local dev only:
PORT=8083
