# ── sentinel-analyst environment variables ──────────────────────────────────
# Set these in Railway. PORT is injected automatically — do NOT override.

# REQUIRED: URL of the running backend (sentinel-backend on Render)
BACKEND_URL=https://sentinel.thronoschain.org

# REQUIRED: Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# ── API Security ──────────────────────────────────────────────────────────────
# Must match API_KEY set on the backend service AND mobile EXPO_PUBLIC_API_KEY.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# Optional overrides
POLL_INTERVAL_S=300          # How often to refresh market context (seconds)
DEFAULT_SYMBOL=BTC/USDT      # Symbol to track
CLAUDE_MODEL=claude-haiku-4-5-20251001   # Cheaper/faster; use claude-sonnet-4-6 for higher quality
LLM_MAX_TOKENS=512
