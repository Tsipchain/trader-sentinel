# ─────────────────────────────────────────────────────────
# Thronos Trader Sentinel — Environment Variables
# Copy to .env for local dev. Set these in Railway for prod.
# ─────────────────────────────────────────────────────────

# Server
# PORT is set automatically by Railway — do NOT override it there.
# For local dev only:
PORT=8081

# ── API Security ──────────────────────────────────────────
# Shared secret between all services and the mobile app.
# If empty, auth is disabled (fine for local dev, NOT for prod).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# ── CEX Market Data (no API keys needed — public endpoints) ──
# Comma-separated list of ccxt exchange IDs
CEX_VENUES=binance,bybit,okx,mexc
# Minimum ms between requests per venue (rate-limit safety)
CEX_MIN_INTERVAL_MS=600

# ── DEX (DexScreener public API) ──
DEXSCREENER_ENABLED=true

# ── Sentinel: NYT Article Search ──
# Get your free key at: https://developer.nytimes.com
# Add here or in Railway env vars. If absent, falls back to RSS only.
NYT_API_KEY=

# ── Google Text-to-Speech (optional) ──
# If false, /api/tts returns {"ok": false}
GOOGLE_TTS_ENABLED=false
# Path to service account JSON (local dev only)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# OR: base64-encoded service account JSON (for Railway/Docker)
# GOOGLE_SA_JSON_BASE64=
GOOGLE_TTS_VOICE=en-US-Neural2-D
GOOGLE_TTS_LANGUAGE=en-US
